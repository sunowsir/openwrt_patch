source /usr/share/libubox/jshn.sh

WORK_DIR="$(dirname "$(readlink -f "${0}")")"
source "${WORK_DIR}/natmap_callback_config"

# ==============================================================
# 日志
# ==============================================================
function log_init() {
    mkdir -p "${LOGS_SAVE_DIR}" 2>/dev/null
    exec >> "${LOGS_SAVE_DIR}${LOGS_FILENAME}" 2>/dev/null
    exec 2>&1
}

function log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "${LOG_FILE}" 
}


# ==============================================================
# 发送通知
# ==============================================================

_sc_send_proc() {
    local text="${1}"
    local desp="${2}"
    local key="${3}"

    local postdata="text=${text}&desp=${desp}"
    local opts=(
        "--header" "Content-type: application/x-www-form-urlencoded"
        "--data" "${postdata}"
    )

    local url="https://sctapi.ftqq.com/${key}.send"
    if [[ "${key}" =~ ^sctp([0-9]+)t ]]; then
        local num="${BASH_REMATCH[1]}"
        url="https://${num}.push.ft07.com/send/${key}.send"
    fi

    local result
    result=$(curl -X POST -s -o /dev/null -w "%{http_code}" "${url}" "${opts[@]}")
    echo "${result}"
}

function sc_send() {
    local notify_title="${1}"
    local public_ipv4="${2}"
    local public_port="${3}"
    local private_ipv4="${4}"
    local private_port="${5}"
    local protocol="${6}"
    local level="${7}"

    if [[ "$(uci -q get "natmap_callback.${private_port}")" != "" ]] && 
       [[ ! $(uci -q get "natmap_callback.${private_port}.notify") ]] &&
       [[ ${level} -eq 0 ]]; then 
        echo "通知已关闭, 跳过"
        return 0
    fi

    # 发送通知
    declare ret
    ret=$(_sc_send_proc "${notify_title}" \
        "${protocol}: ${private_ipv4}:${private_port} --> ${public_ipv4}:${public_port}"$'\n\n' \
        "$SENDKEY")

    if [[ ${ret} -ne 200 ]]; then
        log "推送失败(${*}): ${ret}" 
        return 127
    fi

    log "推送成功"

    return 0
}


# ==============================================================
# API success 检查
# 流程: json_cleanup → json_init → json_load → json_get_var → 判断
# "success":true → let 设=1 → json_get_var 读到 "1" → [[ "$ok" = "1" ]] 成立 → return 0
# "success":false → let 设=0 → json_get_var 读到 "0" → [[ "$ok" = "1" ]] 不成立 → return 1
# ==============================================================
function _cf_api_ok() {
    local resp="$1"
    json_cleanup
    json_init
    json_load "${resp}"
    local ok
    json_get_var ok success
    [[ ${ok} -eq 1 ]] && return 0
    return 1
}

# ==============================================================
# Cloudflare API 请求（带重试）
# ==============================================================

function cf_get() {
    local url="$1"
    for ((i = 0; i < ${RETRY_NUM:-3}; i++)); do
        local resp
        resp="$(curl -s -X GET "${url}" -H "Authorization: Bearer ${AUTH}" \
            -H "Content-Type: application/json")"
        if _cf_api_ok "${resp}"; then
            echo "${resp}"
            return 0
        fi
        log "API GET 失败, 重试 ${i}"
    done
    return 1
}

function cf_put() {
    local url="$1"
    local data="$2"
    for ((i = 0; i < ${RETRY_NUM:-3}; i++)); do
        local resp
        resp="$(curl --connect-timeout "${CURL_CONN_TIMEOUT}" -s -X PUT "${url}" -H "Authorization: Bearer ${AUTH}" \
            -H "Content-Type: application/json" \
            --data "${data}")"
        if _cf_api_ok "${resp}"; then
            return 0
        fi
        log "[DEBUG] $(date) PUT failed, resp: ${resp}"
        log "API PUT 失败（重试 ${i}）"
    done
    return 1
}

# ==============================================================
# Cloudflare API 请求 -- 获取ZONE ID, eg.  zone_id="$(zone_id_from_json "$(zone_id_query)" )"
# ==============================================================

function zone_id_query() {
    cf_get "${CLOUDFLARE_API_URL}?name=${ROOT_DOMAIN}"
}

function zone_id_from_json() {
    local resp="$1"
    json_cleanup
    json_init
    json_load "${resp}"

    json_select "result" || {
        json_cleanup  
        return 1
    }
    json_select 1 || {
        json_cleanup  
        return 1
    }

    local zone_id
    json_get_var zone_id "id"

    json_select ..
    json_select ..

    echo "${zone_id}"
    json_cleanup
}


